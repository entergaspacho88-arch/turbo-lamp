Устройство 5: BQ-SRV

SSH: /etc/openssh/sshd_config. DNS: /var/lib/bind/etc/.
Шаг 1. Имя и сеть
    Команды
su -
hostnamectl set-hostname bq-srv.au-; exec bash

# Проверить текущий адрес: ip addr show bvs3
# Если нужна настройка:
mcedit /etc/net/ifaces/bvs3/options       # Вписать 8 строк (static, как в теории)
mcedit /etc/net/ifaces/bvs3/ipv4address    # 10/10/100/2.27
mcedit /etc/net/ifaces/bvs3/ipv4route      # default via 10/10/100/1
mcedit /etc/net/ifaces/bvs3/resolv.conf    # nameserver 10/10/100/2 2 строка search au-team.irpo
    
systemctl restart network
Шаг 2. Пользователь sshadmin
Создаём пользователя с UID 1025, добавляем в группу wheel, разрешаем sudo без пароля через /etc/sudoers.
    Команды
Сначала проверка
cat /etc/passwd | grep sshuser
id sshuser -u 
cat /etc/sudoers.d/sshuser
cat /etc/group | grep sshuser

Useradd -u 2026 sshuser
passwd sshuser  # P@ssw0rd (два раза)
usermod -aG wheel sshuser

mcedit /etc/sudoers.d/sshuser 
# Найти и раскомментировать строку:
# WHEEL_USERS(вместо этого там нужно написать название юзера) ALL=(ALL) NOPASSWD: ALL
    Проверка
id sshadmin    # uid=2026
su - sshadmin -c 'sudo whoami'    # root без пароля
Шаг 3. SSH
    Команды
mcedit /etc/openssh/sshd_config
# F7 → MaxAuthTries → убрать #, поставить 2
# F7 → Banner → убрать #, вписать /etc/openssh/banner

mcedit /etc/openssh/banner
# Вписать: Authorized access only

sshd -t    # нет вывода = ОК
systemctl restart sshd
systemctl enable sshd

Шаг 4. DNS

mcedit /etc/bind/options.conf
 
    Команды
# Добавить зоны В КОНЕЦ файла:
mcedit /etc/bind/rfc1912.conf
 
Теперь открываем каждый файл зоны в mcedit и вписываем содержимое:
    Прямая зона: au-team.irpo
# mcedit etc/bind/zone/au-team.irpo.zone
     Обратная зона: 10.10.in-addr.arpa
# mcedit etc/bind/zone/10.10.in-addr.arpa.
     
В mcedit вписывай БЕЗ символа # ! Символ # тут только для комментария в гайде.

    Финализация DNS
systemctl enable --now bind.service
    Проверка DNS
dig nq-srv.au- @152.167.100.2 +short   # 152.167.100.2
dig docker.au-team.irpo @152.167.100.2 +short    # 1.1
dig -x 152.167.100.2 @152.167.100.2 +short       # bq-srv.au.
host -t A ya.ru 152.167.100.2                     # forwarders работают
Шаг 5. Часовой пояс
timedatectl set-timezone Europe/Moscow
 
